# Prisma (DB)
DATABASE_URL="postgresql://postgres.your-project:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Prisma Connection Pool 튜닝 (선택, 미설정 시 기본값 사용)
# - PRISMA_CONNECTION_LIMIT : 인스턴스당 최대 DB 커넥션 수
#     기본값 2  — dev/로컬 (Supabase 풀 고갈 방지)
#     권장값 8  — 웹서버/운영 (Supabase pooler 한도 내 테스트용)
#     ※ Supabase Free 플랜 pooler 한도(15)를 넘지 않도록 주의
# - PRISMA_POOL_TIMEOUT : 커넥션 대기 제한(초), 기본값 10
PRISMA_CONNECTION_LIMIT=2
PRISMA_POOL_TIMEOUT=10

# OpenAI (AI 어시스턴트)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o
AI_ENABLED=true

# Custom Auth (generate with: node -e "require('crypto').randomBytes(64).toString('hex')")
DEFAULT_TENANT_ID=tenant-demo-001
JWT_SECRET=your-64-byte-hex-secret
