  tenantId String
  code     String
  name     String
  docType  DocType
  fileUrl  String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  documentLinks DocumentLink[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model DocumentLink {
  id         String @id @default(cuid())
  documentId String
  targetType String
  targetId   String

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, targetType, targetId])
  @@index([documentId])
  @@index([targetType, targetId])
}

model WorkOrder {
  id              String          @id @default(cuid())
  tenantId        String
  siteId          String
  itemId          String
  bomId           String
  routingId       String
  orderNo         String
  manufacturingNo String?
  plannedQty      Decimal         @db.Decimal(18, 6)
  status          WorkOrderStatus @default(DRAFT)
  dueDate         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  site    Site    @relation(fields: [siteId], references: [id])
  item    Item    @relation(fields: [itemId], references: [id])
  bom     BOM     @relation(fields: [bomId], references: [id])
  routing Routing @relation(fields: [routingId], references: [id])

  productionPlanItemId String?
  productionPlanItem   ProductionPlanItem? @relation(fields: [productionPlanItemId], references: [id])

  operations            WorkOrderOperation[]
  materialReservations  MaterialReservation[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  itemCosts             ItemCost[]             @relation("WorkOrderItemCosts")
  materialLots          WorkOrderMaterialLot[]
  wipUnits              WipUnit[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@index([tenantId, siteId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, itemId])
  @@index([productionPlanItemId])
  @@index([tenantId, manufacturingNo])
}

// ─── 의료기기 추적성: 작업지시-제조번호-원자재 LOT 연결 ─────────────────────
model WorkOrderMaterialLot {
  id                     String   @id @default(cuid())
  tenantId               String
  workOrderId            String
  manufacturingNo        String?
  materialItemId         String
  materialLotNo          String
  qty                    Decimal  @db.Decimal(18, 6)
  unit                   String?
  issuedAt               DateTime @default(now())
  issuedBy               String?
  inventoryTransactionId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  workOrder            WorkOrder             @relation(fields: [workOrderId], references: [id])
  materialItem         Item                  @relation("MaterialLotItem", fields: [materialItemId], references: [id])
  inventoryTransaction InventoryTransaction? @relation("MaterialLotInventoryTx", fields: [inventoryTransactionId], references: [id])
  wipUnitMaterialLots  WipUnitMaterialLot[]

  @@index([tenantId])
  @@index([workOrderId])
  @@index([tenantId, manufacturingNo])
  @@index([materialItemId])
  @@index([tenantId, materialLotNo])
  @@index([inventoryTransactionId])
}

model WorkOrderOperation {
  id                 String          @id @default(cuid())
  workOrderId        String
  routingOperationId String
  equipmentId        String?
  seq                Int
  status             OperationStatus @default(PENDING)
  plannedQty         Decimal         @db.Decimal(18, 6)
  completedQty       Decimal         @default(0) @db.Decimal(18, 6)

  workOrder        WorkOrder        @relation(fields: [workOrderId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])
  equipment        Equipment?       @relation(fields: [equipmentId], references: [id])

  materialConsumptions MaterialConsumption[]
  wipUnits             WipUnit[]
  productionResults    ProductionResult[]
  qualityInspections   QualityInspection[]
  wipMovementsFrom     WipMovement[]                  @relation("WipMovementFromOperation")
  wipMovementsTo       WipMovement[]                  @relation("WipMovementToOperation")
  assignments          WorkOrderOperationAssignment[]

  @@unique([workOrderId, seq])
  @@index([workOrderId])
  @@index([routingOperationId])
  @@index([equipmentId])
}

model WorkOrderOperationAssignment {
  id                   String          @id @default(cuid())
  tenantId             String
  workOrderOperationId String
  equipmentId          String
  assignedQty          Decimal         @db.Decimal(18, 6)
  completedQty         Decimal         @default(0) @db.Decimal(18, 6)
  status               OperationStatus @default(PENDING)
  seq                  Int             @default(1)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id], onDelete: Cascade)
  equipment          Equipment          @relation(fields: [equipmentId], references: [id])

  productionResults ProductionResult[]

  @@unique([workOrderOperationId, equipmentId])
  @@index([tenantId])
  @@index([workOrderOperationId])
  @@index([equipmentId])
  @@index([status])
}

model MaterialReservation {
  id          String            @id @default(cuid())
  workOrderId String
  itemId      String
  requiredQty Decimal           @db.Decimal(18, 6)
  reservedQty Decimal           @default(0) @db.Decimal(18, 6)
  issuedQty   Decimal           @default(0) @db.Decimal(18, 6)
  status      ReservationStatus @default(PENDING)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([workOrderId, itemId])
  @@index([workOrderId])
  @@index([itemId])
}

model Lot {
  id              String    @id @default(cuid())
  tenantId        String
  itemId          String
  lotNo           String
  status          LotStatus @default(ACTIVE)
  manufactureDate DateTime?
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  inventoryBalances     InventoryBalance[]
  inventoryTxns         InventoryTransaction[]
  materialConsumptions  MaterialConsumption[]
  wipUnits              WipUnit[]
  wipUnitMaterialLots   WipUnitMaterialLot[]   @relation("WipUnitMaterialLot")
  finishedGoodsReceipts FinishedGoodsReceipt[]
  parentGenealogyLinks  LotGenealogy[]         @relation("ParentLot")
  childGenealogyLinks   LotGenealogy[]         @relation("ChildLot")
  shipmentItems         ShipmentItem[]         @relation("LotShipmentItems")

  @@unique([tenantId, lotNo])
  @@index([tenantId])
  @@index([itemId])
}

model InventoryBalance {
  id           String   @id @default(cuid())
  tenantId     String
  siteId       String
  itemId       String
  lotId        String?
  warehouseId  String
  qtyOnHand    Decimal  @default(0) @db.Decimal(18, 6)
  qtyAvailable Decimal  @default(0) @db.Decimal(18, 6)
  qtyHold      Decimal  @default(0) @db.Decimal(18, 6)
  updatedAt    DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  site      Site      @relation(fields: [siteId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
  lot       Lot?      @relation(fields: [lotId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, itemId, warehouseId, lotId])
  @@index([tenantId])
  @@index([siteId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([tenantId, siteId, itemId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, itemId, lotId, warehouseId])
}

model InventoryTransaction {
  id             String          @id @default(cuid())
  tenantId       String
  itemId         String
  lotId          String?
  fromLocationId String?
  toLocationId   String?
  txNo           String
  txType         TransactionType
  qty            Decimal         @db.Decimal(18, 6)
  refType        String?
  refId          String?
  note           String?
  txAt           DateTime        @default(now())

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  item                  Item                   @relation(fields: [itemId], references: [id])
  lot                   Lot?                   @relation(fields: [lotId], references: [id])
  fromLocation          Warehouse?             @relation("TxFromWarehouse", fields: [fromLocationId], references: [id])
  toLocation            Warehouse?             @relation("TxToWarehouse", fields: [toLocationId], references: [id])
  workOrderMaterialLots WorkOrderMaterialLot[] @relation("MaterialLotInventoryTx")

  @@unique([tenantId, txNo])
  @@index([tenantId])
  @@index([itemId])
  @@index([lotId])
  @@index([txType])
  @@index([txAt])
  @@index([tenantId, txAt])
  @@index([tenantId, itemId, txAt])
  @@index([tenantId, refType, refId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

model MaterialConsumption {
  id                   String  @id @default(cuid())
  workOrderOperationId String
  itemId               String
  lotId                String?
  consumedQty          Decimal @db.Decimal(18, 6)
  scrapQty             Decimal @default(0) @db.Decimal(18, 6)

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])
  item               Item               @relation(fields: [itemId], references: [id])
  lot                Lot?               @relation(fields: [lotId], references: [id])

  @@index([workOrderOperationId])
  @@index([itemId])
  @@index([lotId])
}

model WipUnit {
  id                       String        @id @default(cuid())
  tenantId                 String
  siteId                   String?
  workOrderId              String?
  workOrderOperationId     String
  itemId                   String
  lotId                    String?
  manufacturingNo          String?
  currentWorkCenterId      String?
  currentWarehouseId       String?
  currentLocationId        String?
  outsourcingPartnerId     String?
  sourceProductionResultId String?
  parentWipUnitId          String?
  qty                      Decimal       @db.Decimal(18, 6)
  status                   WipUnitStatus @default(IN_PROCESS)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  tenant                 Tenant               @relation(fields: [tenantId], references: [id])
  site                   Site?                @relation(fields: [siteId], references: [id])
  workOrder              WorkOrder?           @relation(fields: [workOrderId], references: [id])
  workOrderOperation     WorkOrderOperation   @relation(fields: [workOrderOperationId], references: [id])
  item                   Item                 @relation(fields: [itemId], references: [id])
  lot                    Lot?                 @relation(fields: [lotId], references: [id])
  currentLocation        Location?            @relation(fields: [currentLocationId], references: [id])
  currentWorkCenter      WorkCenter?          @relation("WipUnitCurrentWorkCenter", fields: [currentWorkCenterId], references: [id])
  currentWarehouse       Warehouse?           @relation("WipUnitCurrentWarehouse", fields: [currentWarehouseId], references: [id])
  outsourcingPartner     BusinessPartner?     @relation("WipUnitOutsourcingPartner", fields: [outsourcingPartnerId], references: [id])
  sourceProductionResult ProductionResult?    @relation("WipUnitSourceProductionResult", fields: [sourceProductionResultId], references: [id])
  parentWipUnit          WipUnit?             @relation("WipUnitLineage", fields: [parentWipUnitId], references: [id])
  childWipUnits          WipUnit[]            @relation("WipUnitLineage")
  movements              WipMovement[]        @relation("WipUnitMovements")
  relatedMovements       WipMovement[]        @relation("WipMovementRelatedWipUnit")
  materialLots           WipUnitMaterialLot[]

  @@index([tenantId, workOrderId])
  @@index([tenantId, manufacturingNo])
  @@index([tenantId, workOrderOperationId])
  @@index([tenantId, status])
  @@index([tenantId, currentLocationId])
  @@index([tenantId, currentWorkCenterId])
  @@index([tenantId, currentWarehouseId])
  @@index([tenantId, outsourcingPartnerId])
  @@index([tenantId, lotId])
  @@index([workOrderOperationId])
  @@index([itemId])
  @@index([lotId])
  @@index([currentLocationId])
  @@index([status])
  @@index([currentLocationId, status])
}

model WipMovement {
  id               String          @id @default(cuid())
  tenantId         String
  siteId           String?
  wipUnitId        String
  movementType     WipMovementType
  fromOperationId  String?
  toOperationId    String?
  fromWorkCenterId String?
  toWorkCenterId   String?
  fromWarehouseId  String?
  toWarehouseId    String?
  fromLocationId   String?
  toLocationId     String?
  fromPartnerId    String?
  toPartnerId      String?
  relatedWipUnitId String?
  qty              Decimal         @db.Decimal(18, 6)
  sourceType       String?
  sourceId         String?
  note             String?
  createdById      String?
  createdAt        DateTime        @default(now())

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  site           Site?               @relation(fields: [siteId], references: [id])
  wipUnit        WipUnit             @relation("WipUnitMovements", fields: [wipUnitId], references: [id])
  fromOperation  WorkOrderOperation? @relation("WipMovementFromOperation", fields: [fromOperationId], references: [id])
  toOperation    WorkOrderOperation? @relation("WipMovementToOperation", fields: [toOperationId], references: [id])
  fromWorkCenter WorkCenter?         @relation("WipMovementFromWorkCenter", fields: [fromWorkCenterId], references: [id])
  toWorkCenter   WorkCenter?         @relation("WipMovementToWorkCenter", fields: [toWorkCenterId], references: [id])
  fromWarehouse  Warehouse?          @relation("WipMovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse?          @relation("WipMovementToWarehouse", fields: [toWarehouseId], references: [id])
  fromLocation   Location?           @relation("WipMovementFromLocation", fields: [fromLocationId], references: [id])
  toLocation     Location?           @relation("WipMovementToLocation", fields: [toLocationId], references: [id])
  fromPartner    BusinessPartner?    @relation("WipMovementFromPartner", fields: [fromPartnerId], references: [id])
  toPartner      BusinessPartner?    @relation("WipMovementToPartner", fields: [toPartnerId], references: [id])
  relatedWipUnit WipUnit?            @relation("WipMovementRelatedWipUnit", fields: [relatedWipUnitId], references: [id])

  @@index([tenantId, wipUnitId])
  @@index([tenantId, movementType])
  @@index([tenantId, createdAt])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, fromOperationId])
  @@index([tenantId, toOperationId])
  @@index([tenantId, relatedWipUnitId])
}

model WipUnitMaterialLot {
  id                     String   @id @default(cuid())
  tenantId               String
  wipUnitId              String
  workOrderMaterialLotId String?
  materialItemId         String
  materialLotId          String?
  materialLotNo          String?
  qty                    Decimal  @db.Decimal(18, 6)
  unit                   String?
  linkedAt               DateTime @default(now())

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  wipUnit              WipUnit               @relation(fields: [wipUnitId], references: [id])
  workOrderMaterialLot WorkOrderMaterialLot? @relation(fields: [workOrderMaterialLotId], references: [id])
  materialItem         Item                  @relation("WipUnitMaterialItem", fields: [materialItemId], references: [id])
  materialLot          Lot?                  @relation("WipUnitMaterialLot", fields: [materialLotId], references: [id])

  @@index([tenantId, wipUnitId])
  @@index([tenantId, workOrderMaterialLotId])
  @@index([tenantId, materialItemId])
  @@index([tenantId, materialLotId])
  @@index([tenantId, materialLotNo])
}

model ProductionResult {
  id                             String    @id @default(cuid())
  workOrderOperationId           String
  workOrderOperationAssignmentId String?
  goodQty                        Decimal   @default(0) @db.Decimal(18, 6)
  defectQty                      Decimal   @default(0) @db.Decimal(18, 6)
  reworkQty                      Decimal   @default(0) @db.Decimal(18, 6)
  startedAt                      DateTime?
  endedAt                        DateTime?

  workOrderOperation           WorkOrderOperation            @relation(fields: [workOrderOperationId], references: [id])
  workOrderOperationAssignment WorkOrderOperationAssignment? @relation(fields: [workOrderOperationAssignmentId], references: [id])
  sourceWipUnits               WipUnit[]                     @relation("WipUnitSourceProductionResult")

  @@index([workOrderOperationId])
  @@index([workOrderOperationAssignmentId])
