  updatedAt    DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])

  @@unique([tenantId, loginId])
  @@unique([tenantId, popPinFingerprint])
  @@index([tenantId])
}

model LoginHistory {
  id         String           @id @default(cuid())
  tenantId   String
  loginId    String
  profileId  String?
  eventType  LoginEventType
  failReason LoginFailReason?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime         @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([tenantId])
  @@index([profileId])
  @@index([loginId, createdAt])
}

// ─── Support Request ──────────────────────────────────────────────────────────

model SupportRequest {
  id          String          @id @default(cuid())
  tenantId    String
  authorId    String
  type        SupportType
  priority    SupportPriority @default(NORMAL)
  title       String
  content     String          @db.Text
  status      SupportStatus   @default(OPEN)
  imageUrl    String?
  answer      String?         @db.Text
  adminNote   String?         @db.Text
  handledById String?
  handledAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  author    Profile  @relation("SupportAuthor", fields: [authorId], references: [id])
