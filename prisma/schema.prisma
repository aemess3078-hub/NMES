  qualityInspection QualityInspection @relation(fields: [qualityInspectionId], references: [id])
  defectCode        DefectCode        @relation(fields: [defectCodeId], references: [id])

  @@index([qualityInspectionId])
  @@index([defectCodeId])
}

model LotGenealogy {
