}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  featureId String
  isEnabled Boolean  @default(true)
  enabledAt DateTime @default(now())
  config    Json?

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  feature FeatureDefinition @relation(fields: [featureId], references: [id])

  @@unique([tenantId, featureId])
  @@index([tenantId])
}

// ─── Equipment Integration ────────────────────────────────────────────────────

model EdgeGateway {
  id            String        @id @default(cuid())
  tenantId      String
  siteId        String
  name          String
  description   String?
  apiKey        String        @unique @default(cuid())
  status        GatewayStatus @default(OFFLINE)
  lastHeartbeat DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  site        Site                  @relation(fields: [siteId], references: [id])
  connections EquipmentConnection[]

  @@index([tenantId])
}

model EquipmentConnection {
  id          String             @id @default(cuid())
  equipmentId String
  gatewayId   String
  protocol    ConnectionProtocol
  host        String?
  port        Int?
  config      Json?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  equipment Equipment   @relation(fields: [equipmentId], references: [id])
  gateway   EdgeGateway @relation(fields: [gatewayId], references: [id])
  tags      DataTag[]

  @@unique([equipmentId, gatewayId])
}

model DataTag {
  id           String      @id @default(cuid())
  connectionId String
  tagCode      String
  displayName  String
  dataType     TagDataType
  unit         String?
  category     TagCategory
  plcAddress   String
  scaleFactor  Decimal?    @db.Decimal(18, 6)
  offset       Decimal?    @db.Decimal(18, 6)
  samplingMs   Int         @default(1000)
  deadband     Decimal?    @db.Decimal(18, 6)
  isActive     Boolean     @default(true)
  isEnabled    Boolean     @default(true)  @map("is_enabled")
  isVisible    Boolean     @default(true)  @map("is_visible")
  isPrimary    Boolean     @default(false) @map("is_primary")
  displayOrder Int         @default(0)     @map("display_order")
  source       String?     @map("source")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  connection   EquipmentConnection @relation(fields: [connectionId], references: [id])
  snapshots    TagSnapshot[]
  currentValue TagCurrentValue?

  @@unique([connectionId, tagCode])
  @@index([connectionId])
}

model TagSnapshot {
  id        String   @id @default(cuid())
  tagId     String
  value     String
  quality   String   @default("GOOD")
  timestamp DateTime @default(now())

  tag DataTag @relation(fields: [tagId], references: [id])

  @@index([tagId, timestamp])
}

model TagCurrentValue {
  id           String   @id @default(cuid())
  tagId        String   @unique
  value        String
  numericValue Decimal? @db.Decimal(18, 6)
  quality      String   @default("GOOD")
  timestamp    DateTime

  tag DataTag @relation(fields: [tagId], references: [id])
}

model EquipmentEvent {
  id          String             @id @default(cuid())
  equipmentId String
  eventType   EquipmentEventType
  message     String?
  startedAt   DateTime           @default(now())
  endedAt     DateTime?
  duration    Int?

  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId, startedAt])
}

// ─── Phase 2d-5: 영업관리 ─────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  PARTIAL_SHIPPED
  SHIPPED
  CLOSED
  CANCELLED
}

enum ShipmentStatus {
  PLANNED
  PICKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model SalesOrder {
  id           String           @id @default(cuid())
  tenantId     String
  siteId       String
  customerId   String
  orderNo      String
  orderDate    DateTime
  deliveryDate DateTime
  status       SalesOrderStatus @default(DRAFT)
  totalAmount  Decimal?         @db.Decimal(18, 2)
  currency     String           @default("KRW")
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant    Tenant            @relation("TenantSalesOrders", fields: [tenantId], references: [id])
  site      Site              @relation("SiteSalesOrders", fields: [siteId], references: [id])
  customer  BusinessPartner   @relation("CustomerSalesOrders", fields: [customerId], references: [id])
  items     SalesOrderItem[]
  shipments ShipmentOrder[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([tenantId, deliveryDate])
}

model SalesOrderItem {
  id           String    @id @default(cuid())
  salesOrderId String
  itemId       String
  qty          Decimal   @db.Decimal(18, 6)
  unitPrice    Decimal?  @db.Decimal(18, 2)
  deliveryDate DateTime?
  producedQty  Decimal   @default(0) @db.Decimal(18, 6)
  shippedQty   Decimal   @default(0) @db.Decimal(18, 6)
  note         String?

  salesOrder          SalesOrder           @relation(fields: [salesOrderId], references: [id])
  item                Item                 @relation("ItemSalesOrderItems", fields: [itemId], references: [id])
  productionPlanItems ProductionPlanItem[]
  shipmentItems       ShipmentItem[]

  @@unique([salesOrderId, itemId])
  @@index([salesOrderId])
  @@index([itemId])
}

model ShipmentOrder {
  id            String         @id @default(cuid())
  tenantId      String
  siteId        String
  salesOrderId  String
  shipmentNo    String
  status        ShipmentStatus @default(PLANNED)
  plannedDate   DateTime
  shippedDate   DateTime?
  deliveredDate DateTime?
  warehouseId   String?
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant     Tenant         @relation("TenantShipmentOrders", fields: [tenantId], references: [id])
  site       Site           @relation("SiteShipmentOrders", fields: [siteId], references: [id])
  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id])
  warehouse  Warehouse?     @relation("WarehouseShipments", fields: [warehouseId], references: [id])
  items      ShipmentItem[]

  @@unique([tenantId, shipmentNo])
  @@index([tenantId])
  @@index([salesOrderId])
}

model ShipmentItem {
  id               String  @id @default(cuid())
  shipmentOrderId  String
  salesOrderItemId String
  itemId           String
  qty              Decimal @db.Decimal(18, 6)
  lotId            String?

  shipmentOrder  ShipmentOrder  @relation(fields: [shipmentOrderId], references: [id])
  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])
  item           Item           @relation("ItemShipmentItems", fields: [itemId], references: [id])
  lot            Lot?           @relation("LotShipmentItems", fields: [lotId], references: [id])

  @@index([shipmentOrderId])
  @@index([salesOrderItemId])
}

// ─── Phase 2d-6: 구매관리 ─────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum ReceivingInspectionResult {
  PASS
  FAIL
  CONDITIONAL
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  siteId       String
  supplierId   String
  orderNo      String
  orderDate    DateTime
  expectedDate DateTime
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Decimal?            @db.Decimal(18, 2)
  currency     String              @default("KRW")
  note         String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant   Tenant              @relation("TenantPurchaseOrders", fields: [tenantId], references: [id])
  site     Site                @relation("SitePurchaseOrders", fields: [siteId], references: [id])
  supplier BusinessPartner     @relation("SupplierPurchaseOrders", fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  itemId          String
  qty             Decimal @db.Decimal(18, 6)
  unitPrice       Decimal @db.Decimal(18, 2)
  receivedQty     Decimal @default(0) @db.Decimal(18, 6)
  stockAtOrder    Decimal @default(0) @db.Decimal(18, 6)
  note            String?

  purchaseOrder        PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  item                 Item                  @relation("ItemPurchaseOrderItems", fields: [itemId], references: [id])
  receivingInspections ReceivingInspection[]

  @@unique([purchaseOrderId, itemId])
  @@index([purchaseOrderId])
  @@index([itemId])
}

model ReceivingInspection {
  id                  String                    @id @default(cuid())
  purchaseOrderItemId String
  inspectorId         String?
  receivedQty         Decimal                   @db.Decimal(18, 6)
  acceptedQty         Decimal                   @db.Decimal(18, 6)
  rejectedQty         Decimal                   @default(0) @db.Decimal(18, 6)
  result              ReceivingInspectionResult
  inspectedAt         DateTime                  @default(now())
  note                String?

  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  inspector         Profile?          @relation("ReceivingInspector", fields: [inspectorId], references: [id])

  @@index([purchaseOrderItemId])
}

model ItemPrice {
  id            String    @id @default(cuid())
  tenantId      String
  itemId        String
  partnerId     String
  priceType     String
  unitPrice     Decimal   @db.Decimal(18, 2)
  currency      String    @default("KRW")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  note          String?
  createdAt     DateTime  @default(now())

  tenant  Tenant          @relation("TenantItemPrices", fields: [tenantId], references: [id])
  item    Item            @relation("ItemPrices", fields: [itemId], references: [id])
  partner BusinessPartner @relation("PartnerPrices", fields: [partnerId], references: [id])

  @@index([tenantId, itemId, partnerId])
  @@index([tenantId, priceType])
}

// ─── Phase 2d-AI: AI 사용량 로그 ────────────────────────────────────────────

model AIUsageLog {
  id               String   @id @default(cuid())
  tenantId         String
  feature          String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costEstimate     Decimal? @db.Decimal(10, 6)
  requestSummary   String?
  createdAt        DateTime @default(now())

  tenant Tenant @relation("TenantAIUsageLogs", fields: [tenantId], references: [id])

  @@index([tenantId, feature])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// ─── Phase 2d-8: 견적관리 ─────────────────────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SUBMITTED
  NEGOTIATING
  WON
  LOST
  EXPIRED
  CANCELLED
}

model Quotation {
  id                    String          @id @default(cuid())
  tenantId              String
  siteId                String
  customerId            String
  quotationNo           String
  quotationDate         DateTime
  validUntil            DateTime
  status                QuotationStatus @default(DRAFT)
  totalAmount           Decimal?        @db.Decimal(18, 2)
  currency              String          @default("KRW")
  note                  String?
  convertedSalesOrderId String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant   Tenant          @relation("TenantQuotations", fields: [tenantId], references: [id])
  site     Site            @relation("SiteQuotations", fields: [siteId], references: [id])
  customer BusinessPartner @relation("CustomerQuotations", fields: [customerId], references: [id])
  items    QuotationItem[]

  @@unique([tenantId, quotationNo])
  @@index([tenantId, status])
  @@index([customerId])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  itemId      String
  qty         Decimal @db.Decimal(18, 6)
  unitPrice   Decimal @db.Decimal(18, 2)
  note        String?

  quotation Quotation @relation(fields: [quotationId], references: [id])
  item      Item      @relation("ItemQuotationItems", fields: [itemId], references: [id])

  @@unique([quotationId, itemId])
  @@index([quotationId])
  @@index([itemId])
}

// ─── Phase 2d-9: 원가관리 ─────────────────────────────────────────────────────

model ItemCost {
  id           String   @id @default(cuid())
  tenantId     String
  itemId       String
  costType     String
  materialCost Decimal  @db.Decimal(18, 2)
  laborCost    Decimal  @db.Decimal(18, 2)
  overheadCost Decimal  @db.Decimal(18, 2)
  totalCost    Decimal  @db.Decimal(18, 2)
  bomId        String?
  workOrderId  String?
  calculatedAt DateTime @default(now())
  note         String?

  tenant    Tenant     @relation("TenantItemCosts", fields: [tenantId], references: [id])
  item      Item       @relation("ItemCosts", fields: [itemId], references: [id])
  bom       BOM?       @relation("BOMItemCosts", fields: [bomId], references: [id])
  workOrder WorkOrder? @relation("WorkOrderItemCosts", fields: [workOrderId], references: [id])

  @@index([tenantId, itemId, costType])
  @@index([tenantId, calculatedAt])
  @@index([bomId])
  @@index([workOrderId])
}

// ─── Phase 2d-10: 변경관리 (ECN/ECO) ─────────────────────────────────────────

model EngineeringChange {
  id            String    @id @default(cuid())
  tenantId      String
  ecnNo         String
  title         String
  reason        String
  changeType    String
  targetItemId  String
  status        ECNStatus @default(DRAFT)
  requestedBy   String
  approvedBy    String?
  requestedAt   DateTime  @default(now())
  approvedAt    DateTime?
  implementedAt DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant    Tenant                    @relation("TenantECNs", fields: [tenantId], references: [id])
  item      Item                      @relation("ItemECNs", fields: [targetItemId], references: [id])
  requester Profile                   @relation("ECNRequester", fields: [requestedBy], references: [id])
  approver  Profile?                  @relation("ECNApprover", fields: [approvedBy], references: [id])
  details   EngineeringChangeDetail[]

  @@unique([tenantId, ecnNo])
  @@index([tenantId, status])
  @@index([targetItemId])
}

model EngineeringChangeDetail {
  id                  String  @id @default(cuid())
  engineeringChangeId String
  changeTarget        String
  actionType          String
  beforeValue         Json?
  afterValue          Json?
  description         String?

  engineeringChange EngineeringChange @relation(fields: [engineeringChangeId], references: [id])

  @@index([engineeringChangeId])
}

// ─── LMS: 설비관리 (수리요청/일상점검) ───────────────────────────────────────

enum RepairRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RepairPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CheckResult {
  PASS
  FAIL
  NA
}

// ─── Support Request Enums ────────────────────────────────────────────────────

enum SupportType {
  BUG_REPORT
  FEATURE_REQUEST
  IMPROVEMENT
  OTHER
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  ANSWERED
  ON_HOLD
  COMPLETED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model EquipmentProblemType {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  category    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant                   @relation(fields: [tenantId], references: [id])
  repairRequests EquipmentRepairRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model EquipmentRepairRequest {
  id            String              @id @default(cuid())
  tenantId      String
  siteId        String
  equipmentId   String
  problemTypeId String?
  requestNo     String
  title         String
  description   String?
  priority      RepairPriority      @default(MEDIUM)
  status        RepairRequestStatus @default(OPEN)
  requestedBy   String
  assignedTo    String?
  startedAt     DateTime?
  completedAt   DateTime?
  note          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  site        Site                  @relation(fields: [siteId], references: [id])
  equipment   Equipment             @relation(fields: [equipmentId], references: [id])
  problemType EquipmentProblemType? @relation(fields: [problemTypeId], references: [id])
  requester   Profile               @relation("RepairRequester", fields: [requestedBy], references: [id])
  assignee    Profile?              @relation("RepairAssignee", fields: [assignedTo], references: [id])

  @@unique([tenantId, requestNo])
  @@index([tenantId])
  @@index([equipmentId])
  @@index([status])
}

model EquipmentDailyCheck {
  id          String      @id @default(cuid())
  tenantId    String
  siteId      String
  equipmentId String
  checkDate   DateTime    @db.Date
  checkedBy   String
  result      CheckResult @default(PASS)
  note        String?
  items       Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  site      Site      @relation(fields: [siteId], references: [id])
  equipment Equipment @relation(fields: [equipmentId], references: [id])
  checker   Profile   @relation("DailyCheckChecker", fields: [checkedBy], references: [id])

  @@unique([equipmentId, checkDate])
  @@index([tenantId])
  @@index([equipmentId, checkDate])
}

// ─── Custom Auth ─────────────────────────────────────────────────────────────

model UserCredential {
  id           String    @id @default(cuid())
  tenantId     String
  loginId      String
  profileId    String    @unique
  passwordHash String
  popPinHash        String?
  popPinFingerprint String?
  popPinSetAt       DateTime?
