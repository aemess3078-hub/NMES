generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum SiteType {
  FACTORY
  WAREHOUSE
  OFFICE
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum ItemType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED
  CONSUMABLE
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum UOM {
  EA
  KG
  G
  L
  ML
  M
  CM
  MM
  BOX
  SET
}

enum BOMStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum RoutingStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum WorkCenterKind {
  ASSEMBLY
  MACHINING
  INSPECTION
  PACKAGING
  STORAGE
}

enum EquipmentType {
  MACHINE
  TOOL
  JIG
  FIXTURE
  VEHICLE
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum WorkOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OperationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ReservationStatus {
  PENDING
  PARTIAL
  FULFILLED
  CANCELLED
}

enum LotStatus {
  ACTIVE
  QUARANTINE
  ON_HOLD
  CONSUMED
  EXPIRED
}

enum TransactionType {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUST
  RETURN
  SCRAP
}

enum WipUnitStatus {
  IN_PROCESS
  ON_HOLD
  COMPLETED
  SCRAPPED
}

enum InspectionResult {
  PASS
  FAIL
  CONDITIONAL
}

enum DefectSeverity {
  CRITICAL
  MAJOR
  MINOR
}

enum DefectDisposition {
  SCRAP
  REWORK
  ACCEPT
  USE_AS_IS
}

enum DefectCategory {
  DIMENSIONAL
  VISUAL
  FUNCTIONAL
  MATERIAL
}

enum DocType {
  SOP
  DRAWING
  SPEC
  CERTIFICATE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}

enum InspectionInputType {
  NUMERIC
  TEXT
  BOOLEAN
  SELECT
}

enum LotGenealogyRelation {
  INPUT
  OUTPUT
  REWORK
}

enum InspectionSpecStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum AuditActorType {
  USER
  SYSTEM
  BATCH
  API
}

enum PlanType {
  DAILY
  WEEKLY
  MONTHLY
}

enum PlanStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  APPROVE
  EXPORT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sites                 Site[]
  tenantUsers           TenantUser[]
  businessPartners      BusinessPartner[]
  itemCategories        ItemCategory[]
  items                 Item[]
  warehouses            Warehouse[]
  lotRules              LotRule[]
  lots                  Lot[]
  inventoryBalances     InventoryBalance[]
  inventoryTxns         InventoryTransaction[]
  workOrders            WorkOrder[]
  defectCodes           DefectCode[]
  documents             Document[]
  inspectionSpecs       InspectionSpec[]
  auditLogs             AuditLog[]
  approvalRequests      ApprovalRequest[]
  equipments            Equipment[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  boms                  BOM[]
  routings              Routing[]
  productionPlans       ProductionPlan[]
  codeGroups            CodeGroup[]
  rolePermissions       RolePermission[]
  tenantFeatures        TenantFeature[]
}

model Profile {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantUsers        TenantUser[]
  qualityInspections QualityInspection[]
  auditLogs          AuditLog[]
  approvalRequests   ApprovalRequest[]   @relation("Requester")
  approvals          ApprovalRequest[]   @relation("Approver")
}

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  type      SiteType @default(FACTORY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  tenantUsers           TenantUser[]
  workCenters           WorkCenter[]
  warehouses            Warehouse[]
  workOrders            WorkOrder[]
  inventoryBalances     InventoryBalance[]
  equipments            Equipment[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  productionPlans       ProductionPlan[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  profileId String
  siteId    String?
  role      UserRole @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])
  site    Site?   @relation(fields: [siteId], references: [id])

  @@index([tenantId])
  @@index([profileId])
  @@index([siteId])
  @@index([tenantId, profileId])
  @@index([tenantId, siteId, role])
}

model WorkCenter {
  id        String         @id @default(cuid())
  siteId    String
  code      String
  name      String
  kind      WorkCenterKind @default(ASSEMBLY)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  site              Site               @relation(fields: [siteId], references: [id])
  equipments        Equipment[]
  routingOperations RoutingOperation[]

  @@unique([siteId, code])
  @@index([siteId])
}

model BusinessPartner {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  partnerType PartnerType
  status      PartnerStatus @default(ACTIVE)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ItemCategory {
  id           String  @id @default(cuid())
  tenantId     String
  parentId     String?
  code         String
  name         String
  displayOrder Int     @default(0)

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryTree")
  items    Item[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

model Item {
  id              String     @id @default(cuid())
  tenantId        String
  categoryId      String?
  code            String
  name            String
  itemType        ItemType
  uom             UOM        @default(EA)
  spec            String?
  isLotTracked    Boolean    @default(false)
  isSerialTracked Boolean    @default(false)
  status          ItemStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  category ItemCategory? @relation(fields: [categoryId], references: [id])

  substitutes           ItemSubstitute[]       @relation("PrimaryItem")
  substituteOf          ItemSubstitute[]       @relation("SubstituteItem")
  boms                  BOM[]
  bomItems              BOMItem[]
  routings              Routing[]
  lots                  Lot[]
  lotRules              LotRule[]
  inspectionSpecs       InspectionSpec[]
  inventoryBalances     InventoryBalance[]
  inventoryTxns         InventoryTransaction[]
  workOrders            WorkOrder[]
  materialReservations  MaterialReservation[]
  materialConsumptions  MaterialConsumption[]
  wipUnits              WipUnit[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  productionPlanItems   ProductionPlanItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([categoryId])
}

model ItemSubstitute {
  id               String @id @default(cuid())
  itemId           String
  substituteItemId String
  priority         Int    @default(1)

  item           Item @relation("PrimaryItem", fields: [itemId], references: [id])
  substituteItem Item @relation("SubstituteItem", fields: [substituteItemId], references: [id])

  @@unique([itemId, substituteItemId])
  @@index([itemId])
}

model BOM {
  id        String    @id @default(cuid())
  tenantId  String
  itemId    String
  version   String
  isDefault Boolean   @default(false)
  status    BOMStatus @default(DRAFT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  item       Item        @relation(fields: [itemId], references: [id])
  bomItems   BOMItem[]
  workOrders WorkOrder[]
  productionPlanItems ProductionPlanItem[]

  @@unique([tenantId, itemId, version])
  @@index([tenantId])
  @@index([itemId])
}

model BOMItem {
  id              String  @id @default(cuid())
  bomId           String
  componentItemId String
  seq             Int
  qtyPer          Decimal @db.Decimal(18, 6)
  scrapRate       Decimal @default(0) @db.Decimal(5, 4)

  bom           BOM  @relation(fields: [bomId], references: [id])
  componentItem Item @relation(fields: [componentItemId], references: [id])

  @@unique([bomId, seq])
  @@index([bomId])
  @@index([componentItemId])
}

model Routing {
  id        String        @id @default(cuid())
  tenantId  String
  itemId    String
  version   String
  isDefault Boolean       @default(false)
  status    RoutingStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  item       Item               @relation(fields: [itemId], references: [id])
  operations RoutingOperation[]
  workOrders WorkOrder[]
  productionPlanItems ProductionPlanItem[]

  @@unique([tenantId, itemId, version])
  @@index([tenantId])
  @@index([itemId])
}

model RoutingOperation {
  id            String  @id @default(cuid())
  routingId     String
  workCenterId  String
  seq           Int
  operationCode String
  name          String
  standardTime  Decimal @default(0) @db.Decimal(10, 2)

  routing    Routing    @relation(fields: [routingId], references: [id])
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  equipmentMaps       EquipmentOperationMap[]
  workOrderOperations WorkOrderOperation[]
  inspectionSpecs     InspectionSpec[]

  @@unique([routingId, seq])
  @@index([routingId])
  @@index([workCenterId])
}

model Equipment {
  id            String          @id @default(cuid())
  tenantId      String
  siteId        String
  workCenterId  String
  code          String
  name          String
  equipmentType EquipmentType
  status        EquipmentStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  site       Site       @relation(fields: [siteId], references: [id])
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  operationMaps       EquipmentOperationMap[]
  workOrderOperations WorkOrderOperation[]

  @@unique([siteId, code])
  @@index([tenantId])
  @@index([siteId])
  @@index([workCenterId])
}

model EquipmentOperationMap {
  id                 String @id @default(cuid())
  equipmentId        String
  routingOperationId String

  equipment        Equipment        @relation(fields: [equipmentId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])

  @@unique([equipmentId, routingOperationId])
  @@index([equipmentId])
  @@index([routingOperationId])
}

model Warehouse {
  id       String @id @default(cuid())
  tenantId String
  siteId   String
  code     String
  name     String

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  site                  Site                   @relation(fields: [siteId], references: [id])
  locations             Location[]
  finishedGoodsReceipts FinishedGoodsReceipt[]

  @@unique([siteId, code])
  @@index([tenantId])
  @@index([siteId])
}

model Location {
  id           String  @id @default(cuid())
  warehouseId  String
  code         String
  name         String
  locationType String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  inventoryBalances     InventoryBalance[]
  inventoryTxnsFrom     InventoryTransaction[] @relation("FromLocation")
  inventoryTxnsTo       InventoryTransaction[] @relation("ToLocation")
  wipUnits              WipUnit[]
  finishedGoodsReceipts FinishedGoodsReceipt[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model LotRule {
  id         String  @id @default(cuid())
  tenantId   String
  itemId     String
  prefix     String?
  dateFormat String?
  seqLength  Int     @default(4)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  @@unique([tenantId, itemId])
  @@index([tenantId])
}

model InspectionSpec {
  id                 String               @id @default(cuid())
  tenantId           String
  itemId             String
  routingOperationId String
  version            String
  status             InspectionSpecStatus @default(DRAFT)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  item             Item             @relation(fields: [itemId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])

  inspectionItems    InspectionItem[]
  qualityInspections QualityInspection[]

  @@unique([tenantId, itemId, routingOperationId, version])
  @@index([tenantId])
  @@index([itemId])
  @@index([routingOperationId])
}

model InspectionItem {
  id               String              @id @default(cuid())
  inspectionSpecId String
  seq              Int
  name             String
  inputType        InspectionInputType @default(NUMERIC)
  lowerLimit       Decimal?            @db.Decimal(18, 6)
  upperLimit       Decimal?            @db.Decimal(18, 6)

  inspectionSpec InspectionSpec @relation(fields: [inspectionSpecId], references: [id])

  @@unique([inspectionSpecId, seq])
  @@index([inspectionSpecId])
}

model DefectCode {
  id             String         @id @default(cuid())
  tenantId       String
  code           String
  name           String
  defectCategory DefectCategory

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  defectRecords DefectRecord[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Document {
  id       String  @id @default(cuid())
  tenantId String
  code     String
  name     String
  docType  DocType
  fileUrl  String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  documentLinks DocumentLink[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model DocumentLink {
  id         String @id @default(cuid())
  documentId String
  targetType String
  targetId   String

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, targetType, targetId])
  @@index([documentId])
  @@index([targetType, targetId])
}

model WorkOrder {
  id         String          @id @default(cuid())
  tenantId   String
  siteId     String
  itemId     String
  bomId      String
  routingId  String
  orderNo    String
  plannedQty Decimal         @db.Decimal(18, 6)
  status     WorkOrderStatus @default(DRAFT)
  dueDate    DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  site    Site    @relation(fields: [siteId], references: [id])
  item    Item    @relation(fields: [itemId], references: [id])
  bom     BOM     @relation(fields: [bomId], references: [id])
  routing Routing @relation(fields: [routingId], references: [id])

  productionPlanItemId String?
  productionPlanItem   ProductionPlanItem? @relation(fields: [productionPlanItemId], references: [id])

  operations            WorkOrderOperation[]
  materialReservations  MaterialReservation[]
  finishedGoodsReceipts FinishedGoodsReceipt[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@index([tenantId, siteId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, itemId])
  @@index([productionPlanItemId])
}

model WorkOrderOperation {
  id                 String          @id @default(cuid())
  workOrderId        String
  routingOperationId String
  equipmentId        String?
  seq                Int
  status             OperationStatus @default(PENDING)
  plannedQty         Decimal         @db.Decimal(18, 6)
  completedQty       Decimal         @default(0) @db.Decimal(18, 6)

  workOrder        WorkOrder        @relation(fields: [workOrderId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])
  equipment        Equipment?       @relation(fields: [equipmentId], references: [id])

  materialConsumptions MaterialConsumption[]
  wipUnits             WipUnit[]
  productionResults    ProductionResult[]
  qualityInspections   QualityInspection[]

  @@unique([workOrderId, seq])
  @@index([workOrderId])
  @@index([routingOperationId])
  @@index([equipmentId])
}

model MaterialReservation {
  id          String            @id @default(cuid())
  workOrderId String
  itemId      String
  requiredQty Decimal           @db.Decimal(18, 6)
  reservedQty Decimal           @default(0) @db.Decimal(18, 6)
  issuedQty   Decimal           @default(0) @db.Decimal(18, 6)
  status      ReservationStatus @default(PENDING)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([workOrderId, itemId])
  @@index([workOrderId])
  @@index([itemId])
}

model Lot {
  id              String    @id @default(cuid())
  tenantId        String
  itemId          String
  lotNo           String
  status          LotStatus @default(ACTIVE)
  manufactureDate DateTime?
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  inventoryBalances     InventoryBalance[]
  inventoryTxns         InventoryTransaction[]
  materialConsumptions  MaterialConsumption[]
  wipUnits              WipUnit[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  parentGenealogyLinks  LotGenealogy[]         @relation("ParentLot")
  childGenealogyLinks   LotGenealogy[]         @relation("ChildLot")

  @@unique([tenantId, lotNo])
  @@index([tenantId])
  @@index([itemId])
}

model InventoryBalance {
  id           String   @id @default(cuid())
  tenantId     String
  siteId       String
  itemId       String
  lotId        String?
  locationId   String
  qtyOnHand    Decimal  @default(0) @db.Decimal(18, 6)
  qtyAvailable Decimal  @default(0) @db.Decimal(18, 6)
  qtyHold      Decimal  @default(0) @db.Decimal(18, 6)
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  site     Site     @relation(fields: [siteId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])
  lot      Lot?     @relation(fields: [lotId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([itemId])
  @@index([locationId])
  @@index([tenantId, siteId, itemId])
  @@index([tenantId, locationId])
  @@index([tenantId, itemId, lotId, locationId])
}

model InventoryTransaction {
  id             String          @id @default(cuid())
  tenantId       String
  itemId         String
  lotId          String?
  fromLocationId String?
  toLocationId   String?
  txNo           String
  txType         TransactionType
  qty            Decimal         @db.Decimal(18, 6)
  refType        String?
  refId          String?
  txAt           DateTime        @default(now())

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  item         Item      @relation(fields: [itemId], references: [id])
  lot          Lot?      @relation(fields: [lotId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])

  @@unique([tenantId, txNo])
  @@index([tenantId])
  @@index([itemId])
  @@index([lotId])
  @@index([txType])
  @@index([txAt])
  @@index([tenantId, txAt])
  @@index([tenantId, itemId, txAt])
  @@index([tenantId, refType, refId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

model MaterialConsumption {
  id                   String  @id @default(cuid())
  workOrderOperationId String
  itemId               String
  lotId                String?
  consumedQty          Decimal @db.Decimal(18, 6)
  scrapQty             Decimal @default(0) @db.Decimal(18, 6)

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])
  item               Item               @relation(fields: [itemId], references: [id])
  lot                Lot?               @relation(fields: [lotId], references: [id])

  @@index([workOrderOperationId])
  @@index([itemId])
  @@index([lotId])
}

model WipUnit {
  id                   String        @id @default(cuid())
  workOrderOperationId String
  itemId               String
  lotId                String?
  currentLocationId    String?
  qty                  Decimal       @db.Decimal(18, 6)
  status               WipUnitStatus @default(IN_PROCESS)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])
  item               Item               @relation(fields: [itemId], references: [id])
  lot                Lot?               @relation(fields: [lotId], references: [id])
  currentLocation    Location?          @relation(fields: [currentLocationId], references: [id])

  @@index([workOrderOperationId])
  @@index([itemId])
  @@index([lotId])
  @@index([currentLocationId])
  @@index([status])
  @@index([currentLocationId, status])
}

model ProductionResult {
  id                   String    @id @default(cuid())
  workOrderOperationId String
  goodQty              Decimal   @default(0) @db.Decimal(18, 6)
  defectQty            Decimal   @default(0) @db.Decimal(18, 6)
  reworkQty            Decimal   @default(0) @db.Decimal(18, 6)
  startedAt            DateTime?
  endedAt              DateTime?

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])

  @@index([workOrderOperationId])
}

model FinishedGoodsReceipt {
  id          String   @id @default(cuid())
  tenantId    String
  siteId      String
  workOrderId String
  itemId      String
  lotId       String?
  warehouseId String
  locationId  String
  receiptQty  Decimal  @db.Decimal(18, 6)
  receiptAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  site      Site      @relation(fields: [siteId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
  lot       Lot?      @relation(fields: [lotId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  location  Location  @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([workOrderId])
  @@index([itemId])
  @@index([lotId])
  @@index([tenantId, siteId, receiptAt])
  @@index([warehouseId, locationId])
}

model QualityInspection {
  id                   String            @id @default(cuid())
  workOrderOperationId String
  inspectionSpecId     String
  inspectorId          String
  result               InspectionResult?
  inspectedQty         Decimal           @db.Decimal(18, 6)
  inspectedAt          DateTime          @default(now())

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])
  inspectionSpec     InspectionSpec     @relation(fields: [inspectionSpecId], references: [id])
  inspector          Profile            @relation(fields: [inspectorId], references: [id])

  defectRecords DefectRecord[]

  @@index([workOrderOperationId])
  @@index([inspectionSpecId])
  @@index([inspectorId])
  @@index([workOrderOperationId, inspectedAt])
  @@index([inspectorId, inspectedAt])
}

model DefectRecord {
  id                  String             @id @default(cuid())
  qualityInspectionId String
  defectCodeId        String
  qty                 Decimal            @db.Decimal(18, 6)
  severity            DefectSeverity     @default(MAJOR)
  disposition         DefectDisposition?

  qualityInspection QualityInspection @relation(fields: [qualityInspectionId], references: [id])
  defectCode        DefectCode        @relation(fields: [defectCodeId], references: [id])

  @@index([qualityInspectionId])
  @@index([defectCodeId])
}

model LotGenealogy {
  id           String               @id @default(cuid())
  parentLotId  String
  childLotId   String
  relationType LotGenealogyRelation @default(OUTPUT)
  qty          Decimal              @db.Decimal(18, 6)

  parentLot Lot @relation("ParentLot", fields: [parentLotId], references: [id])
  childLot  Lot @relation("ChildLot", fields: [childLotId], references: [id])

  @@unique([parentLotId, childLotId, relationType])
  @@index([parentLotId])
  @@index([childLotId])
}

model AuditLog {
  id         String         @id @default(cuid())
  tenantId   String
  actorId    String?
  actorType  AuditActorType @default(USER)
  actorLabel String?
  entityType String
  entityId   String
  action     AuditAction
  beforeData Json?
  afterData  Json?
  actedAt    DateTime       @default(now())

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  actor  Profile? @relation(fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([actedAt])
  @@index([tenantId, entityType, entityId, actedAt])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  tenantId    String
  requesterId String
  approverId  String?
  requestType String
  targetType  String
  targetId    String
  status      ApprovalStatus @default(PENDING)
  requestedAt DateTime       @default(now())
  approvedAt  DateTime?

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  requester Profile  @relation("Requester", fields: [requesterId], references: [id])
  approver  Profile? @relation("Approver", fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([requesterId])
  @@index([approverId])
  @@index([status])
  @@index([status, requestedAt])
  @@index([tenantId, targetType, targetId])
}

model ProductionPlan {
  id        String     @id @default(cuid())
  tenantId  String
  siteId    String
  planNo    String
  planType  PlanType
  startDate DateTime
  endDate   DateTime
  status    PlanStatus @default(DRAFT)
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant               @relation(fields: [tenantId], references: [id])
  site   Site                 @relation(fields: [siteId], references: [id])
  items  ProductionPlanItem[]

  @@unique([tenantId, planNo])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
}

model ProductionPlanItem {
  id          String  @id @default(cuid())
  planId      String
  itemId      String
  bomId       String?
  routingId   String?
  plannedQty  Decimal @db.Decimal(18, 6)
  note        String?

  plan      ProductionPlan @relation(fields: [planId], references: [id])
  item      Item           @relation(fields: [itemId], references: [id])
  bom       BOM?           @relation(fields: [bomId], references: [id])
  routing   Routing?       @relation(fields: [routingId], references: [id])
  workOrders WorkOrder[]

  @@unique([planId, itemId])
  @@index([planId])
  @@index([itemId])
}

model CodeGroup {
  id          String   @id @default(cuid())
  tenantId    String
  groupCode   String
  groupName   String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  codes  CommonCode[]

  @@unique([tenantId, groupCode])
  @@index([tenantId])
}

model CommonCode {
  id           String   @id @default(cuid())
  groupId      String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  extra        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group CodeGroup @relation(fields: [groupId], references: [id])

  @@unique([groupId, code])
  @@index([groupId])
}

model RolePermission {
  id        String           @id @default(cuid())
  tenantId  String
  role      UserRole
  resource  String
  action    PermissionAction
  isAllowed Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, resource, action])
  @@index([tenantId])
  @@index([role])
  @@index([resource])
}

model FeatureDefinition {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  category     String
  icon         String?
  menuCodes    String[]
  isCore       Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dependencies   FeatureDependency[] @relation("Feature")
  dependedBy     FeatureDependency[] @relation("DependsOn")
  requirements   FeatureRequirement[]
  tenantFeatures TenantFeature[]
}

model FeatureDependency {
  id          String  @id @default(cuid())
  featureId   String
  dependsOnId String
  isRequired  Boolean @default(true)

  feature   FeatureDefinition @relation("Feature", fields: [featureId], references: [id])
  dependsOn FeatureDefinition @relation("DependsOn", fields: [dependsOnId], references: [id])

  @@unique([featureId, dependsOnId])
}

model FeatureRequirement {
  id          String @id @default(cuid())
  featureId   String
  type        String
  target      String
  description String?

  feature FeatureDefinition @relation(fields: [featureId], references: [id])

  @@index([featureId])
}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  featureId String
  isEnabled Boolean  @default(true)
  enabledAt DateTime @default(now())
  config    Json?

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  feature FeatureDefinition @relation(fields: [featureId], references: [id])

  @@unique([tenantId, featureId])
  @@index([tenantId])
}
