generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum SiteType {
  FACTORY
  WAREHOUSE
  OFFICE
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum ItemType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED
  CONSUMABLE
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum LotNumberingType {
  DEFAULT
  MANUAL
  RAW_DATE_SEQ
  PREFIX_MONTH_SEQ
}

enum ManualLotPolicy {
  ALLOWED
  REQUIRED
  DISABLED
}

enum UOM {
  EA
  KG
  G
  L
  ML
  M
  CM
  MM
  BOX
  SET
}

enum BOMStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum RoutingStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum WorkCenterKind {
  ASSEMBLY
  MACHINING
  INSPECTION
  PACKAGING
  STORAGE
}

enum EquipmentType {
  MACHINE
  TOOL
  JIG
  FIXTURE
  VEHICLE
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum WorkOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OperationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ReservationStatus {
  PENDING
  PARTIAL
  FULFILLED
  CANCELLED
}

enum LotStatus {
  ACTIVE
  QUARANTINE
  ON_HOLD
  CONSUMED
  EXPIRED
}

enum TransactionType {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUST
  RETURN
  SCRAP
}

enum WipUnitStatus {
  WAITING
  IN_PROCESS
  ON_HOLD
  OUTSOURCED
  IN_TRANSIT
  RECEIVED
  COMPLETED
  SCRAPPED
  REWORK
}

enum WipMovementType {
  CREATED
  STARTED
  MOVED
  HOLD
  RELEASED
  SPLIT
  MERGE
  DEFECT
  REWORK
  SCRAP
  OUTSOURCED
  RETURNED
  COMPLETED
  ADJUSTED
}

enum InspectionResult {
  PASS
  FAIL
  CONDITIONAL
}

enum DefectSeverity {
  CRITICAL
  MAJOR
  MINOR
}

enum DefectDisposition {
  SCRAP
  REWORK
  ACCEPT
  USE_AS_IS
}

enum DefectCategory {
  DIMENSIONAL
  VISUAL
  FUNCTIONAL
  MATERIAL
}

enum DocType {
  SOP
  DRAWING
  SPEC
  CERTIFICATE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum SignupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}

enum InspectionInputType {
  NUMERIC
  TEXT
  BOOLEAN
  SELECT
}

enum LotGenealogyRelation {
  INPUT
  OUTPUT
  REWORK
}

enum InspectionSpecStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum AuditActorType {
  USER
  SYSTEM
  BATCH
  API
}

enum PlanType {
  DAILY
  WEEKLY
  MONTHLY
}

enum PlanStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  APPROVE
  EXPORT
}

enum ConnectionProtocol {
  OPC_UA
  MODBUS_TCP
  MQTT
  MC_PROTOCOL
  S7
  FOCAS
  CUSTOM
  NCWATCH_AGENT
}

enum TagDataType {
  BOOL
  INT
  FLOAT
  STRING
}

enum TagCategory {
  PROCESS
  STATUS
  ALARM
  COUNTER
  QUALITY
}

enum GatewayStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum ECNStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  IMPLEMENTED
  CANCELLED
}

enum EquipmentEventType {
  RUN
  STOP
  ALARM
  WARNING
  MAINTENANCE
}

enum LoginEventType {
  LOGIN_SUCCESS
  LOGIN_FAIL
  LOGOUT
}

enum LoginFailReason {
  USER_NOT_FOUND
  INVALID_PASSWORD
  PENDING_APPROVAL
  HOLD
  REJECTED
  INACTIVE
  LOCKED
  DELETED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sites                         Site[]
  tenantUsers                   TenantUser[]
  businessPartners              BusinessPartner[]
  itemCategories                ItemCategory[]
  items                         Item[]
  warehouses                    Warehouse[]
  numberingRules                NumberingRule[]
  lots                          Lot[]
  inventoryBalances             InventoryBalance[]
  inventoryTxns                 InventoryTransaction[]
  workOrders                    WorkOrder[]
  defectCodes                   DefectCode[]
  documents                     Document[]
  inspectionSpecs               InspectionSpec[]
  auditLogs                     AuditLog[]
  approvalRequests              ApprovalRequest[]
  equipments                    Equipment[]
  finishedGoodsReceipts         FinishedGoodsReceipt[]
  wipUnits                      WipUnit[]
  wipMovements                  WipMovement[]
  wipUnitMaterialLots           WipUnitMaterialLot[]
  boms                          BOM[]
  routings                      Routing[]
  itemRoutings                  ItemRouting[]
  productionPlans               ProductionPlan[]
  codeGroups                    CodeGroup[]
  rolePermissions               RolePermission[]
  tenantFeatures                TenantFeature[]
  gateways                      EdgeGateway[]
  salesOrders                   SalesOrder[]                   @relation("TenantSalesOrders")
  shipmentOrders                ShipmentOrder[]                @relation("TenantShipmentOrders")
  purchaseOrders                PurchaseOrder[]                @relation("TenantPurchaseOrders")
  itemPrices                    ItemPrice[]                    @relation("TenantItemPrices")
  aiUsageLogs                   AIUsageLog[]                   @relation("TenantAIUsageLogs")
  quotations                    Quotation[]                    @relation("TenantQuotations")
  itemCosts                     ItemCost[]                     @relation("TenantItemCosts")
  engineeringChanges            EngineeringChange[]            @relation("TenantECNs")
  signupRequests                SignupRequest[]
  equipmentProblemTypes         EquipmentProblemType[]
  equipmentRepairs              EquipmentRepairRequest[]
  equipmentDailyChecks          EquipmentDailyCheck[]
  userCredentials               UserCredential[]
  loginHistories                LoginHistory[]
  itemGroups                    ItemGroup[]
  workOrderOperationAssignments WorkOrderOperationAssignment[]
  supportRequests               SupportRequest[]
}

model Profile {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  avatarUrl  String?
  department String?
  phone      String?
  employeeNo String?
  jobTitle   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantUsers          TenantUser[]
  qualityInspections   QualityInspection[]
  auditLogs            AuditLog[]
  approvalRequests     ApprovalRequest[]        @relation("Requester")
  approvals            ApprovalRequest[]        @relation("Approver")
  receivingInspections ReceivingInspection[]    @relation("ReceivingInspector")
  ecnRequested         EngineeringChange[]      @relation("ECNRequester")
  ecnApproved          EngineeringChange[]      @relation("ECNApprover")
  signupsApproved      SignupRequest[]          @relation("SignupApprover")
  signupsRejected      SignupRequest[]          @relation("SignupRejector")
  repairRequested      EquipmentRepairRequest[] @relation("RepairRequester")
  repairAssigned       EquipmentRepairRequest[] @relation("RepairAssignee")
  dailyChecks          EquipmentDailyCheck[]    @relation("DailyCheckChecker")
  userCredential       UserCredential?
  loginHistories       LoginHistory[]
  supportAuthored      SupportRequest[]         @relation("SupportAuthor")
  supportHandled       SupportRequest[]         @relation("SupportHandler")
}

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  type      SiteType @default(FACTORY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                   @relation(fields: [tenantId], references: [id])
  tenantUsers           TenantUser[]
  workCenters           WorkCenter[]
  warehouses            Warehouse[]
  workOrders            WorkOrder[]
  inventoryBalances     InventoryBalance[]
  equipments            Equipment[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  wipUnits              WipUnit[]
  wipMovements          WipMovement[]
  productionPlans       ProductionPlan[]
  gateways              EdgeGateway[]
  salesOrders           SalesOrder[]             @relation("SiteSalesOrders")
  shipmentOrders        ShipmentOrder[]          @relation("SiteShipmentOrders")
  purchaseOrders        PurchaseOrder[]          @relation("SitePurchaseOrders")
  quotations            Quotation[]              @relation("SiteQuotations")
  equipmentRepairs      EquipmentRepairRequest[]
  equipmentDailyChecks  EquipmentDailyCheck[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  profileId String
  siteId    String?
  role      UserRole @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])
  site    Site?   @relation(fields: [siteId], references: [id])

  @@index([tenantId])
  @@index([profileId])
  @@index([siteId])
  @@index([tenantId, profileId])
  @@index([tenantId, siteId, role])
}

model SignupRequest {
  id            String              @id @default(cuid())
  tenantId      String
  loginId       String?
  email         String
  name          String
  department    String?
  employeeNo    String?
  phone         String?
  jobTitle      String?
  passwordHash  String?
  popPinHash        String?
  popPinFingerprint String?
  popPinSetAt       DateTime?
  requestedRole UserRole            @default(OPERATOR)
  status        SignupRequestStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectedById  String?
  rejectReason  String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  approvedBy Profile? @relation("SignupApprover", fields: [approvedById], references: [id])
  rejectedBy Profile? @relation("SignupRejector", fields: [rejectedById], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([email])
  @@index([tenantId, loginId])
  @@index([tenantId, popPinFingerprint])
}

model WorkCenter {
  id        String         @id @default(cuid())
  siteId    String
  code      String
  name      String
  kind      WorkCenterKind @default(ASSEMBLY)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  site              Site               @relation(fields: [siteId], references: [id])
  equipments        Equipment[]
  routingOperations RoutingOperation[]
  currentWipUnits   WipUnit[]          @relation("WipUnitCurrentWorkCenter")
  wipMovementsFrom  WipMovement[]      @relation("WipMovementFromWorkCenter")
  wipMovementsTo    WipMovement[]      @relation("WipMovementToWorkCenter")

  @@unique([siteId, code])
  @@index([siteId])
}

model BusinessPartner {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  partnerType PartnerType
  status      PartnerStatus @default(ACTIVE)

  // 연락처/상세 정보 (전부 선택, 기존 데이터는 null)
  businessNumber String? // 사업자등록번호
  ceoName        String? // 대표자명
  phone          String? // 전화번호
  email          String? // 이메일1 (대표 이메일)
  email2         String? // 이메일2 (담당자/추가 이메일)
  address        String? // 주소
  contactName    String? // 담당자명
  contactPhone   String? // 담당자연락처
  remark         String? // 비고

  tenant                  Tenant          @relation(fields: [tenantId], references: [id])
  salesOrders             SalesOrder[]    @relation("CustomerSalesOrders")
  purchaseOrders          PurchaseOrder[] @relation("SupplierPurchaseOrders")
  itemPrices              ItemPrice[]     @relation("PartnerPrices")
  quotations              Quotation[]     @relation("CustomerQuotations")
  outsourcedWipUnits      WipUnit[]       @relation("WipUnitOutsourcingPartner")
  wipMovementsFromPartner WipMovement[]   @relation("WipMovementFromPartner")
  wipMovementsToPartner   WipMovement[]   @relation("WipMovementToPartner")

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ItemCategory {
  id           String    @id @default(cuid())
  tenantId     String
  parentId     String?
  code         String
  name         String
  itemType     ItemType?
  displayOrder Int       @default(0)

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  parent     ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   ItemCategory[] @relation("CategoryTree")
  items      Item[]
  itemGroups ItemGroup[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

model ItemGroup {
  id           String   @id @default(cuid())
  tenantId     String
  categoryId   String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  category ItemCategory @relation(fields: [categoryId], references: [id])
  items    Item[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([categoryId])
}

model Item {
  id              String     @id @default(cuid())
  tenantId        String
  categoryId      String?
  itemGroupId     String?
  code            String
  name            String
  itemType        ItemType
  uom             UOM        @default(EA)
  spec            String?
  isLotTracked    Boolean    @default(false)
  isSerialTracked Boolean    @default(false)
  lotNumberingType LotNumberingType @default(DEFAULT)
  lotPrefix      String?
  manualLotPolicy ManualLotPolicy @default(ALLOWED)
  status          ItemStatus @default(ACTIVE)
  defaultWarehouseId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  category         ItemCategory? @relation(fields: [categoryId], references: [id])
  itemGroup        ItemGroup?    @relation(fields: [itemGroupId], references: [id])
  defaultWarehouse Warehouse?    @relation("ItemDefaultWarehouse", fields: [defaultWarehouseId], references: [id])

  substitutes             ItemSubstitute[]       @relation("PrimaryItem")
  substituteOf            ItemSubstitute[]       @relation("SubstituteItem")
  boms                    BOM[]
  bomItems                BOMItem[]
  itemRoutings            ItemRouting[]
  lots                    Lot[]
  inspectionSpecs         InspectionSpec[]
  inventoryBalances       InventoryBalance[]
  inventoryTxns           InventoryTransaction[]
  workOrders              WorkOrder[]
  materialReservations    MaterialReservation[]
  materialConsumptions    MaterialConsumption[]
  wipUnits                WipUnit[]
  wipUnitMaterialLots     WipUnitMaterialLot[]   @relation("WipUnitMaterialItem")
  finishedGoodsReceipts   FinishedGoodsReceipt[]
  productionPlanItems     ProductionPlanItem[]
  salesOrderItems         SalesOrderItem[]       @relation("ItemSalesOrderItems")
  shipmentItems           ShipmentItem[]         @relation("ItemShipmentItems")
  purchaseOrderItems      PurchaseOrderItem[]    @relation("ItemPurchaseOrderItems")
  itemPrices              ItemPrice[]            @relation("ItemPrices")
  quotationItems          QuotationItem[]        @relation("ItemQuotationItems")
  itemCosts               ItemCost[]             @relation("ItemCosts")
  engineeringChanges      EngineeringChange[]    @relation("ItemECNs")
  materialLotConsumptions WorkOrderMaterialLot[] @relation("MaterialLotItem")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([categoryId])
  @@index([itemGroupId])
  @@index([defaultWarehouseId])
}

model ItemSubstitute {
  id               String @id @default(cuid())
  itemId           String
  substituteItemId String
  priority         Int    @default(1)

  item           Item @relation("PrimaryItem", fields: [itemId], references: [id])
  substituteItem Item @relation("SubstituteItem", fields: [substituteItemId], references: [id])

  @@unique([itemId, substituteItemId])
  @@index([itemId])
}

model BOM {
  id        String    @id @default(cuid())
  tenantId  String
  itemId    String
  version   String
  isDefault Boolean   @default(false)
  status    BOMStatus @default(DRAFT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  item                Item                 @relation(fields: [itemId], references: [id])
  bomItems            BOMItem[]
  workOrders          WorkOrder[]
  productionPlanItems ProductionPlanItem[]
  itemCosts           ItemCost[]           @relation("BOMItemCosts")

  @@unique([tenantId, itemId, version])
  @@index([tenantId])
  @@index([itemId])
}

model BOMItem {
  id              String  @id @default(cuid())
  bomId           String
  componentItemId String
  seq             Int
  qtyPer          Decimal @db.Decimal(18, 6)
  scrapRate       Decimal @default(0) @db.Decimal(5, 4)

  bom           BOM  @relation(fields: [bomId], references: [id])
  componentItem Item @relation(fields: [componentItemId], references: [id])

  @@unique([bomId, seq])
  @@index([bomId])
  @@index([componentItemId])
}

model Routing {
  id        String        @id @default(cuid())
  tenantId  String
  code      String
  name      String
  version   String
  status    RoutingStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  items               ItemRouting[]
  operations          RoutingOperation[]
  workOrders          WorkOrder[]
  productionPlanItems ProductionPlanItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ItemRouting {
  id        String  @id @default(cuid())
  tenantId  String
  itemId    String
  routingId String
  isDefault Boolean @default(false)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  item    Item    @relation(fields: [itemId], references: [id])
  routing Routing @relation(fields: [routingId], references: [id])

  @@unique([itemId, routingId])
  @@index([itemId])
  @@index([routingId])
}

model RoutingOperation {
  id            String  @id @default(cuid())
  routingId     String
  workCenterId  String
  seq           Int
  operationCode String
  name          String
  standardTime  Decimal @default(0) @db.Decimal(10, 2)

  routing    Routing    @relation(fields: [routingId], references: [id])
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  equipmentMaps       EquipmentOperationMap[]
  workOrderOperations WorkOrderOperation[]
  inspectionSpecs     InspectionSpec[]

  @@unique([routingId, seq])
  @@index([routingId])
  @@index([workCenterId])
}

model Equipment {
  id            String          @id @default(cuid())
  tenantId      String
  siteId        String
  workCenterId  String
  code          String
  name          String
  equipmentType EquipmentType
  status        EquipmentStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  site       Site       @relation(fields: [siteId], references: [id])
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  operationMaps                 EquipmentOperationMap[]
  workOrderOperations           WorkOrderOperation[]
  connections                   EquipmentConnection[]
  events                        EquipmentEvent[]
  repairRequests                EquipmentRepairRequest[]
  dailyChecks                   EquipmentDailyCheck[]
  workOrderOperationAssignments WorkOrderOperationAssignment[]
  ncwatchMappings               NcwatchEquipmentMapping[]      @relation("EquipmentNcwatchMappings")

  @@unique([siteId, code])
  @@index([tenantId])
  @@index([siteId])
  @@index([workCenterId])
}

model EquipmentOperationMap {
  id                 String @id @default(cuid())
  equipmentId        String
  routingOperationId String

  equipment        Equipment        @relation(fields: [equipmentId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])

  @@unique([equipmentId, routingOperationId])
  @@index([equipmentId])
  @@index([routingOperationId])
}

model Warehouse {
  id       String  @id @default(cuid())
  tenantId String
  siteId   String
  code     String
  name     String
  zone     String?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  site                  Site                   @relation(fields: [siteId], references: [id])
  locations             Location[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  shipments             ShipmentOrder[]        @relation("WarehouseShipments")
  inventoryBalances     InventoryBalance[]
  inventoryTxnsFrom     InventoryTransaction[] @relation("TxFromWarehouse")
  inventoryTxnsTo       InventoryTransaction[] @relation("TxToWarehouse")
  currentWipUnits       WipUnit[]              @relation("WipUnitCurrentWarehouse")
  wipMovementsFrom      WipMovement[]          @relation("WipMovementFromWarehouse")
  wipMovementsTo        WipMovement[]          @relation("WipMovementToWarehouse")
  defaultForItems       Item[]                 @relation("ItemDefaultWarehouse")

  @@unique([siteId, code])
  @@index([tenantId])
  @@index([siteId])
}

model Location {
  id           String  @id @default(cuid())
  warehouseId  String
  code         String
  name         String
  locationType String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  wipUnits              WipUnit[]
  finishedGoodsReceipts FinishedGoodsReceipt[]
  wipMovementsFrom      WipMovement[]          @relation("WipMovementFromLocation")
  wipMovementsTo        WipMovement[]          @relation("WipMovementToLocation")

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

enum NumberingRuleType {
  LOT
  SERIAL
}

model NumberingRule {
  id        String            @id @default(cuid())
  tenantId  String
  type      NumberingRuleType
  tokens    Json
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  sequences NumberingSequence[]

  @@unique([tenantId, type])
  @@index([tenantId])
}

model NumberingSequence {
  id        String @id @default(cuid())
  ruleId    String
  periodKey String
  current   Int    @default(0)

  rule NumberingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, periodKey])
}

model InspectionSpec {
  id                 String               @id @default(cuid())
  tenantId           String
  itemId             String
  routingOperationId String
  version            String
  status             InspectionSpecStatus @default(DRAFT)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  item             Item             @relation(fields: [itemId], references: [id])
  routingOperation RoutingOperation @relation(fields: [routingOperationId], references: [id])

  inspectionItems    InspectionItem[]
  qualityInspections QualityInspection[]

  @@unique([tenantId, itemId, routingOperationId, version])
  @@index([tenantId])
  @@index([itemId])
  @@index([routingOperationId])
}

model InspectionItem {
  id               String              @id @default(cuid())
  inspectionSpecId String
  seq              Int
  name             String
  inputType        InspectionInputType @default(NUMERIC)
  lowerLimit       Decimal?            @db.Decimal(18, 6)
  upperLimit       Decimal?            @db.Decimal(18, 6)

  inspectionSpec InspectionSpec @relation(fields: [inspectionSpecId], references: [id])

  @@unique([inspectionSpecId, seq])
  @@index([inspectionSpecId])
}

model DefectCode {
