enum InspectionStage {
  FIRST
  MID
  FINAL
}

model QualityInspection {
  id                   String            @id @default(cuid())
  workOrderOperationId String
  inspectionSpecId     String
  inspectorId          String
  stage                InspectionStage   @default(MID)
  result               InspectionResult?
  inspectedQty         Decimal           @db.Decimal(18, 6)
  inspectedAt          DateTime          @default(now())

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id])
  inspectionSpec     InspectionSpec     @relation(fields: [inspectionSpecId], references: [id])
  inspector          Profile            @relation(fields: [inspectorId], references: [id])

  defectRecords DefectRecord[]

  @@index([workOrderOperationId])
  @@index([inspectionSpecId])
  @@index([inspectorId])
  @@index([workOrderOperationId, inspectedAt])
  @@index([inspectorId, inspectedAt])
}

model DefectRecord {
  id                  String             @id @default(cuid())
  qualityInspectionId String
  defectCodeId        String
  qty                 Decimal            @db.Decimal(18, 6)
  severity            DefectSeverity     @default(MAJOR)
